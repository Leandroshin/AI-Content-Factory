# ==================================================
# AI Content Factory — .gitignore
# ==================================================

# Secrets / environment
.env
.env.*
!.env.example
secrets/
!core/tools/secrets/
!core/tools/secrets/**
*.key
*.pem
*.p12
*.pfx

# Python caches / bytecode
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
.pytest_cache/
.mypy_cache/
.pytype/
.ruff_cache/
.tox/
.nox/
.coverage
htmlcov/

# Build artifacts
dist/
build/
site/
.eggs/
pip-wheel-metadata/

# Virtual environments
.venv/
venv/
ENV/
env/

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# Project outputs
.ai_company/
output/*
!output/.gitkeep
temp/*
!temp/.gitkeep
research_inputs/raw_transcripts/
research_inputs/manual_candidates/
logs/
*.log
.cache/
*.tmp
*.temp

# Large media / generated assets
assets/videos/
assets/audio/
*.mp4
*.mp3
*.wav
*.avi
*.mov
*.mkv
*.flac
*.aac

# Misc
conversa inteira.txt
RespostaLLMS/
.ipynb_checkpoints/
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
