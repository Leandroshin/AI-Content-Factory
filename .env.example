# ==================================================
# AI Content Factory — Variáveis de Ambiente
# ==================================================
# Copie este arquivo para .env e preencha com seus valores reais.
# NUNCA commite o arquivo .env no Git.
# ==================================================

# --------------------------------------------------
# LLM Providers
# --------------------------------------------------
# OpenAI (GPT-4, GPT-4o)
OPENAI_API_KEY=your_key_here

# Anthropic (Claude)
ANTHROPIC_API_KEY=your_key_here

# Google (Gemini)
GOOGLE_API_KEY=your_key_here

# --------------------------------------------------
# Text-to-Speech (TTS)
# --------------------------------------------------
# ElevenLabs (provider primário)
ELEVENLABS_API_KEY=your_key_here

# --------------------------------------------------
# Plataformas de Publicação (futuro)
# --------------------------------------------------
# YouTube
# YOUTUBE_CLIENT_ID=your_client_id_here
# YOUTUBE_CLIENT_SECRET=your_client_secret_here

# TikTok
# TIKTOK_API_KEY=your_key_here

# Meta Ads Analytics (somente leitura)
# Prefira secrets/meta_ads.env em vez do .env geral.
# META_ACCESS_TOKEN=your_ads_read_token
# META_GRAPH_API_VERSION=vXX.X
# META_AD_ACCOUNT_ID=your_numeric_ad_account_id

# --------------------------------------------------
# Armazenamento (futuro)
# --------------------------------------------------
# AWS S3 / MinIO
# AWS_ACCESS_KEY_ID=your_key_here
# AWS_SECRET_ACCESS_KEY=your_key_here
# AWS_S3_BUCKET=your_bucket_here

# --------------------------------------------------
# Aplicação
# --------------------------------------------------
# Ambiente: development | staging | production
APP_ENV=development

# Nível de log: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Diretório de output (padrão: ./output)
OUTPUT_DIR=./output

# Diretório temporário (padrão: ./temp)
TEMP_DIR=./temp
